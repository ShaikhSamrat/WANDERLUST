<% layout("/layouts/boilerplate") %> 

<style>
#filters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    padding-top: 30px;
    padding-bottom: 25px;
    margin-top: 10px;
    border-bottom: 1px solid #eeeeee;
}

.filter {
    text-align: center;
    opacity: 0.7;
    cursor: pointer;
}

.filter:hover {
    opacity: 1;
}

.filter p {
    font-size: 0.75rem;
    margin-top: 0.5rem;
}

.fa-regular, .filter i {
    font-size: 1.8rem;
}

.tax-info {
    font-size: 0.85rem;
    color: #666;
}
</style>

<div id="filters">
    <div class="filter" onclick="filterByCategory('Rooms')">
        <div><i class="fa-solid fa-bed"></i></div>
        <p>Rooms</p>
    </div>
    <div class="filter" onclick="filterByCategory('Iconic cities')">
        <div><i class="fa-solid fa-mountain-city"></i></div>
        <p>Iconic cities</p>
    </div>
    <div class="filter" onclick="filterByCategory('Mountains')">
        <div><i class="fa-solid fa-mountain"></i></div>
        <p>Mountains</p>
    </div>
    <div class="filter" onclick="filterByCategory('Castle')">
        <div><i class="fa-brands fa-fort-awesome"></i></div>
        <p>Castle</p>
    </div>
    <div class="filter" onclick="filterByCategory('Amazing Pools')">
        <div><i class="fa-solid fa-person-swimming"></i></div>
        <p>Amazing Pools</p>
    </div>
    <div class="filter" onclick="filterByCategory('Camping')">
        <div><i class="fa-solid fa-campground"></i></div>
        <p>Camping</p>
    </div>
    <div class="filter" onclick="filterByCategory('Boat')">
        <div><i class="fa-solid fa-sailboat"></i></div>
        <p>Boat</p>
    </div>
    <div class="filter" onclick="filterByCategory('Arctic')">
        <div><i class="fa-solid fa-snowman"></i></div>
        <p>Arctic</p>
    </div>
    <div class="filter" onclick="filterByCategory('Domes')">
        <div><i class="fa-solid fa-igloo"></i></div>
        <p>Domes</p>
    </div>

    <div class="tax-toogle ms-auto">
        <div class="form-switch-wrapper">
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault" style="transform: scale(1.1);">
                <label class="form-check-label fw-bold" for="flexSwitchCheckDefault" style="font-size: 0.95rem;">
                    Display total after tax
                </label>
            </div>
        </div>
    </div>
</div>

<% if(typeof filterCategory !== 'undefined' && filterCategory) { %>
    <h4 class="mt-3">Best <%= filterCategory %> stays</h4>
<% } else if(typeof query !== 'undefined' && query) { %>
    <h4 class="mt-3">Search results for "<%= query %>"</h4>
<% } %>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-4">
  <% for(let listing of allListings) { %>
    <a href="/listings/<%= listing._id %>" class="listing-link"> 
      <div class="card col listing-card">
        <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem" />

        <div class="card-body">
          <p class="card-text">
            <b><%= listing.title %></b><br />
            <span class="base-price">
              <b>&#8377;<%= listing.price.toLocaleString("en-IN") %></b> night
            </span>
            <span class="tax-info d-none">
              <b>+18% GST</b> 
              (<b>&#8377;<span class="total-price"></span></b>)
            </span>
          </p>
        </div>
      </div>
    </a>
  <% } %>
</div>

<script>
function filterByCategory(category) {
    window.location.href = `/listings/category/${encodeURIComponent(category)}`;
}

// Tax toggle functionality
const taxSwitch = document.getElementById("flexSwitchCheckDefault");

taxSwitch.addEventListener("change", () => {
  const taxInfos = document.querySelectorAll(".tax-info");
  taxInfos.forEach((taxInfo) => {
    const cardText = taxInfo.parentElement;
    const basePriceEl = cardText.querySelector(".base-price b");
    if (!basePriceEl) return;

    const price = parseInt(basePriceEl.textContent.replace(/[^0-9]/g, ''));

    if (taxSwitch.checked) {
      taxInfo.classList.remove("d-none");
      const totalPriceEl = taxInfo.querySelector(".total-price");
      if (totalPriceEl) {
        totalPriceEl.textContent = Math.round(price * 1.18).toLocaleString("en-IN");
      }
    } else {
      taxInfo.classList.add("d-none");
    }
  });
});
</script>