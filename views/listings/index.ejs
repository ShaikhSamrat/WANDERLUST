<% layout("/layouts/boilerplate") %> 

<style>
#filters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.6rem;
    padding-top: 15px;
    padding-bottom: 25px;
    margin-top: 5px;
    border-bottom: 1px solid #eeeeee;
}

.filter {
    text-align: center;
    opacity: 0.75;
    transition: opacity 0.2s;
}

.filter:hover {
    opacity: 1;
    cursor: pointer;
}

.filter.trending {
    cursor: default;
    opacity: 1;
}

.filter i {
    font-size: 1.85rem;
    display: block;
    margin-bottom: 4px;
    height: 34px;
    line-height: 34px;
}

.filter p {
    font-size: 0.76rem;
    margin: 0;
    font-weight: 500;
    color: #222;
}

/* Tax Toggle Styling */
.tax-toogle {
    margin-left: auto;
}

.tax-toogle .form-switch-wrapper {
    border: 2px solid #222;
    border-radius: 50px;
    padding: 6px 14px;
    background-color: white;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}
</style>

<div id="filters">
    <!-- Trending Icon -->
    <div class="filter trending">
        <div><i class="fa-solid fa-fire"></i></div>
        <p>Trending</p>
    </div>

    <!-- Category Filters -->
    <div class="filter" onclick="filterByCategory('Rooms')">
        <div><i class="fa-solid fa-bed"></i></div>
        <p>Rooms</p>
    </div>
    <div class="filter" onclick="filterByCategory('Iconic cities')">
        <div><i class="fa-solid fa-mountain-city"></i></div>
        <p>Iconic cities</p>
    </div>
    <div class="filter" onclick="filterByCategory('Mountains')">
        <div><i class="fa-solid fa-mountain"></i></div>
        <p>Mountains</p>
    </div>
    <div class="filter" onclick="filterByCategory('Castle')">
        <div><i class="fa-brands fa-fort-awesome"></i></div>
        <p>Castle</p>
    </div>
    <div class="filter" onclick="filterByCategory('Amazing Pools')">
        <div><i class="fa-solid fa-person-swimming"></i></div>
        <p>Amazing Pools</p>
    </div>
    <div class="filter" onclick="filterByCategory('Camping')">
        <div><i class="fa-solid fa-campground"></i></div>
        <p>Camping</p>
    </div>
    <div class="filter" onclick="filterByCategory('Boat')">
        <div><i class="fa-solid fa-sailboat"></i></div>
        <p>Boat</p>
    </div>
    <div class="filter" onclick="filterByCategory('Arctic')">
        <div><i class="fa-solid fa-snowman"></i></div>
        <p>Arctic</p>
    </div>
    <div class="filter" onclick="filterByCategory('Domes')">
        <div><i class="fa-solid fa-igloo"></i></div>
        <p>Domes</p>
    </div>

    <!-- Tax Toggle -->
    <div class="tax-toogle ms-auto">
        <div class="form-switch-wrapper">
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault" style="transform: scale(1.1);">
                <label class="form-check-label fw-bold" for="flexSwitchCheckDefault" style="font-size: 0.95rem;">
                    Display total after tax
                </label>
            </div>
        </div>
    </div>
</div>

<!-- Title Section -->
<% if(typeof filterCategory !== 'undefined' && filterCategory) { %>
    <h4 class="mt-3">Best <%= filterCategory %> stays</h4>
<% } else if(typeof query !== 'undefined' && query) { %>
    <h4 class="mt-3">Search results for "<%= query %>"</h4>
<% } %>

<!-- No Results Message -->
<% if(allListings.length === 0) { %>
    <div class="text-center mt-5">
        <i class="fa-solid fa-magnifying-glass fa-3x text-muted mb-3"></i>
        <h5>No results found</h5>
        <p class="text-muted">We couldn't find any listings matching your search.</p>
        <a href="/listings" class="btn btn-outline-dark mt-3">Browse All Listings</a>
    </div>
<% } else { %>
    <!-- Listings Grid -->
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-4">
      <% for(let listing of allListings) { %>
        <a href="/listings/<%= listing._id %>" class="listing-link"> 
          <div class="card col listing-card">
            <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem" />
            <div class="card-body">
              <p class="card-text">
                <b><%= listing.title %></b><br />
                <span class="base-price">
                  <b>&#8377;<%= listing.price.toLocaleString("en-IN") %>/</b>night
                </span>
                <span class="tax-info d-none small-tax-text">
                  <i>+18% GST</i> 
                  (<i>&#8377;<span class="total-price"></span></i>)
                </span>
              </p>
            </div>
          </div>
        </a>
      <% } %>
    </div>
<% } %>

<script>
// Category Filter Function
function filterByCategory(category) {
    window.location.href = `/listings/category/${encodeURIComponent(category)}`;
}

// Tax Toggle Script
const taxSwitch = document.getElementById("flexSwitchCheckDefault");

if (taxSwitch) {
    taxSwitch.addEventListener("change", () => {
        document.querySelectorAll(".tax-info").forEach(taxInfo => {
            const basePriceEl = taxInfo.parentElement.querySelector(".base-price b");
            if (!basePriceEl) return;
            
            const price = parseInt(basePriceEl.textContent.replace(/[^0-9]/g, ''));
            
            if (taxSwitch.checked) {
                taxInfo.classList.remove("d-none");
                const totalEl = taxInfo.querySelector(".total-price");
                if (totalEl) {
                    totalEl.textContent = Math.round(price * 1.18).toLocaleString("en-IN");
                }
            } else {
                taxInfo.classList.add("d-none");
            }
        });
    });
}
</script> 